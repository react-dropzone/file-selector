{
  "name": "file-selector",
  "version": "0.0.0-development",
  "description": "Convert DataTransfer object to a list of File objects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.*"
  ],
  "keywords": [
    "drag-and-drop",
    "html5",
    "file-api",
    "DataTransfer",
    "File"
  ],
  "homepage": "https://github.com/react-dropzone/file-selector",
  "license": "MIT",
  "author": {
    "name": "Roland Groza",
    "email": "rolandjitsu@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/react-dropzone/file-selector.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "npm run clean",
    "build": "rslib build",
    "dev": "rslib build --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "pretest:cov": "npm run type-check && npm run lint",
    "test": "vitest --project unit",
    "test:cov": "vitest run --project unit --coverage",
    "test:e2e": "vitest run --project browser"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@rslib/core": "^0.23.2",
    "@types/node": "^26.1.1",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">= 20"
  }
}
