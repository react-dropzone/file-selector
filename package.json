{
  "name": "file-selector",
  "version": "0.0.0-development",
  "description": "Convert DataTransfer object to a list of File objects",
  "keywords": [
    "DataTransfer",
    "File",
    "drag-and-drop",
    "file-api",
    "html5"
  ],
  "homepage": "https://github.com/react-dropzone/file-selector",
  "bugs": {
    "url": "https://github.com/react-dropzone/file-selector/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Roland Groza",
    "email": "rolandjitsu@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/react-dropzone/file-selector.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "12.0.1",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">= 22"
  }
}
