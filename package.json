{
  "name": "file-selector",
  "version": "0.0.0-development",
  "description": "Convert DataTransfer object to a list of File objects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.*"
  ],
  "keywords": [
    "drag-and-drop",
    "html5",
    "file-api",
    "DataTransfer",
    "File"
  ],
  "homepage": "https://github.com/react-dropzone/file-selector",
  "license": "MIT",
  "author": {
    "name": "Roland Groza",
    "email": "rolandjitsu@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/react-dropzone/file-selector.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "npm run clean",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:type-aware": "oxlint --type-aware",
    "format": "oxfmt \"src/**/*.ts\" \"*.ts\"",
    "format:check": "oxfmt --check \"src/**/*.ts\" \"*.ts\"",
    "pretest:cov": "npm run type-check && npm run lint && npm run format:check",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">= 20"
  }
}
